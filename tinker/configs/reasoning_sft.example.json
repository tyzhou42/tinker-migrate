{
  "dataset_root_dir": "dataset",
  "dataset_name": "ethos",
  "data_path": "datasets/ethos/Ethos_Dataset_Binary.csv",
  "text_column": "comment",
  "label_column": "isHate",
  "label_threshold": 0.5,
  "csv_sep": ";",
  "seed": 42,

  "prompt_file": "prompts/sft_reasoning.yaml",
  "rl_prompt_file": "prompts/rl_reasoning.yaml",
  "rl_use_rulebook": false,

  "task_instruction": "Decide whether the following text is hate speech.",

  "rules_root_dir": "rules",
  "rules_dir": "rules",
  "rules_glob": "*.txt",

  "teacher_env_file": "../extraction/.env",
  "teacher_api_key_env": "DEEPSEEK_API_KEY",
  "teacher_base_url": "https://api.deepseek.com",
  "teacher_model": "deepseek-chat",
  "teacher_temperature": 0.7,
  "teacher_max_tokens": 4096,
  "teacher_k": 3,
  "teacher_workers": 1,
  "teacher_max_retries": 3,
  "teacher_request_timeout": 90,
  "teacher_json_mode": false,
  "teacher_sleep_seconds": 0.0,

  "student_model_name": "Qwen/Qwen3-8B",
  "student_use_rulebook": true,
  "student_enable_thinking": true,
  "tinker_base_url": null,
  "lora_rank": 32,
  "ttl_seconds": 7776000,

  "num_epochs": 3,
  "batch_size": 16,
  "batch_strategy": "stratified",
  "learning_rate": 0.0002,
  "adam_beta1": 0.9,
  "adam_beta2": 0.95,
  "adam_eps": 1e-08,
  "lr_schedule": "linear",
  "min_lr_ratio": 0.1,

  "max_length": 2048,
  "max_new_tokens": 4096,
  "val_export_every_evals": 0,
  "eval_interval": 10,
  "eval_test_during_train": false,
  "train_checkpoint_e2e_eval": false,
  "max_eval_samples": 0,
  "eval_max_concurrency": 64,
  "eval_reasoning_placeholder": "Reasoning intentionally omitted for label scoring.",
  "invalid_label_warn_rate": 0.1,
  "selection_metric": "macro_f1",

  "min_reasoning_chars": 20,
  "max_train_examples": 0,
  "max_val_examples": 0,
  "max_test_examples": 0,

  "log_dir": "runs",
  "run_name": null,
  "save_sft_jsonl": true,

  "wandb_project": "reasoning-sft-tinker",
  "wandb_entity": null,
  "wandb_mode": "online"
}
